# ==================================
# PollParrot Environment Variables
# ==================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ============================================
# PUBLIC VARIABLES (Safe for browser)
# ============================================
# These are prefixed with NEXT_PUBLIC_ and are safe to expose
# They are protected by Supabase Row Level Security (RLS)

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key (safe to expose - RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application name
NEXT_PUBLIC_APP_NAME=PollParrot

# ============================================
# SECRET VARIABLES (Server-only - NEVER expose)
# ============================================
# These must NEVER have NEXT_PUBLIC_ prefix
# They are only used in server actions, API routes, and scripts

# Supabase service role key (BYPASSES Row Level Security!)
# ⚠️  DANGER: This key has full database access
# ⚠️  NEVER import this in client components
# ⚠️  Only use in: Server Actions, API Routes, scripts/seed.ts
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
